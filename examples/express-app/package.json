{
  "name": "@dexterjs/example-express",
  "version": "0.1.0",
  "private": true,
  "description": "Example Express app instrumented with DexterJS",
  "main": "./dist/index.js",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist *.tsbuildinfo",
    "start": "node dist/index.js",
    "dev": "npx ts-node src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dexterjs/sdk": "workspace:*",
    "@dexterjs/types": "workspace:*",
    "express": "^4.19.0",
    "pg": "^8.12.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/pg": "^8.11.0",
    "typescript": "^5.4.0"
  }
}
