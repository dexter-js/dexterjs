{
  "name": "@dexterjs/sidecar",
  "version": "0.1.0",
  "description": "DexterJS Sidecar — local observability dashboard and aggregator",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc && cp src/dashboard.html dist/dashboard.html",
    "clean": "rm -rf dist *.tsbuildinfo",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dexterjs/types": "workspace:*",
    "better-sqlite3": "^11.0.0",
    "express": "^4.19.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
