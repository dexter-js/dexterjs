{
  "name": "@dexter.js/sdk",
  "version": "0.1.0",
  "description": "DexterJS SDK — meta package that re-exports @dexter.js/logger and @dexter.js/monitor",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist *.tsbuildinfo",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dexter.js/logger": "workspace:*",
    "@dexter.js/monitor": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  }
}
