{
  "name": "@dexter.js/monitor",
  "version": "0.1.0",
  "description": "DexterJS Monitor — auto-instrument your Node.js app with tracing, metrics, and insights",
  "publishConfig": {
    "access": "public"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf dist *.tsbuildinfo",
    "dev": "tsc --watch & nodemon dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@dexter.js/sidecar": "workspace:*",
    "@dexter.js/types": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "typescript": "^5.4.0"
  },
  "peerDependencies": {
    "express": ">=4.0.0",
    "pg": ">=8.0.0",
    "mongoose": ">=7.0.0",
    "ioredis": ">=5.0.0",
    "axios": ">=1.0.0",
    "@prisma/client": ">=5.0.0",
    "drizzle-orm": ">=0.29.0"
  },
  "peerDependenciesMeta": {
    "express": {
      "optional": true
    },
    "pg": {
      "optional": true
    },
    "mongoose": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "axios": {
      "optional": true
    },
    "@prisma/client": {
      "optional": true
    },
    "drizzle-orm": {
      "optional": true
    }
  }
}
